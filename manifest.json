{
  "manifest_version": 3,
  "name": "Click & Save Bookmark",
  "version": "1.1",
  "description": "Save pages to bookmarks with a single click from the context menu.",
  "permissions": [
    "contextMenus",
    "bookmarks",
    "activeTab",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png"
  }
}
